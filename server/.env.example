# Copy to .env and adjust. Used by creator-server (Express + social routes).

# Puppeteer headless fetch for Instagram / TikTok / Facebook (default: on).
# Set to "false" to disable when Chromium is unavailable.
# USE_HEADLESS=false

# Instagram reel/video fallback via Apify (optional).
# https://apify.com — actor used in lib/apifyFetch.js
# APIFY_TOKEN=

# Social POST /fetch: include a "debug" array on the JSON response (omit in public prod).
# SOCIAL_FETCH_DEBUG=true

# yt-dlp: install separately (https://github.com/yt-dlp/yt-dlp).
# Strongly recommended for TikTok/Facebook and when headless cannot pull MP4 bytes.
# Default executable name is yt-dlp on PATH; override on Windows if needed:
# YT_DLP_PATH=C:\path\to\yt-dlp.exe

# Optional Netscape cookies.txt for private or login-gated posts (Instagram/Facebook).
# Export from browser extension; path must be readable by the server process.
# YT_DLP_COOKIES=C:\path\to\cookies.txt
