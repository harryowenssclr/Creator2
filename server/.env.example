# Copy to .env and adjust. Used by creator-server (Express + social routes).

# Puppeteer headless fetch for Instagram / TikTok / Facebook (default: on).
# Set to "false" to disable when Chromium is unavailable.
# USE_HEADLESS=false

# Instagram reel/video fallback via Apify (optional).
# https://apify.com — actor used in lib/apifyFetch.js
# APIFY_TOKEN=

# Social POST /fetch: include a "debug" array on the JSON response (omit in public prod).
# SOCIAL_FETCH_DEBUG=true

# yt-dlp: install separately — https://github.com/yt-dlp/yt-dlp#installation
# Strongly recommended for TikTok/Facebook and stubborn Instagram reels.
#
# Windows (examples — then restart the terminal AND the Node server so PATH updates):
#   winget install yt-dlp.yt-dlp
#   # or: scoop install yt-dlp
#   # or: py -m pip install -U yt-dlp   then ensure Python Scripts is on PATH
# Verify:  yt-dlp --version
#
# If the UI still says yt-dlp missing, point Node at the exe explicitly:
# YT_DLP_PATH=C:\path\to\yt-dlp.exe

# ffmpeg: required for yt-dlp to merge video+audio (most IG/TikTok reels).
# The API often runs with a minimal PATH — set explicitly after winget install:
# FFMPEG_PATH=C:/Users/you/AppData/Local/Microsoft/WinGet/Packages/.../bin/ffmpeg.exe
# Find:  where.exe ffmpeg   (in PowerShell)

# Optional Netscape cookies.txt for private or login-gated posts (Instagram/Facebook).
# Export from browser extension; path must be readable by the server process.
# YT_DLP_COOKIES=C:\path\to\cookies.txt
