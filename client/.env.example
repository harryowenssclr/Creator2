# When the Express server also serves client/dist (recommended: Railway single service),
# leave VITE_API_BASE_URL unset — the browser uses same-origin /api/... .
#
# Only set this if the SPA is hosted on a *different* origin than the API (e.g. Firebase Hosting
# for static + Railway for API). No trailing slash.
# VITE_API_BASE_URL=https://your-api-host.example.com
